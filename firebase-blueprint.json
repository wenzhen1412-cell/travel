{
  "entities": {
    "Trip": {
      "title": "Trip",
      "description": "Travel planning trip information",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Owner user ID" },
        "name": { "type": "string", "description": "Trip name" },
        "destination": { "type": "string", "description": "Trip destination" },
        "startDate": { "type": "string", "description": "Start date of the trip (YYYY-MM-DD)" },
        "endDate": { "type": "string", "description": "End date of the trip (YYYY-MM-DD)" },
        "status": { "type": "string", "enum": ["planning", "ongoing", "completed"], "description": "Trip planning state" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "destination", "startDate", "endDate", "status"]
    },
    "Activity": {
      "title": "Activity",
      "description": "Daily item inside a trip",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Owner user ID" },
        "tripId": { "type": "string", "description": "Associated Trip ID" },
        "name": { "type": "string", "description": "Activity name" },
        "date": { "type": "string", "description": "Activity date (YYYY-MM-DD)" },
        "time": { "type": "string", "description": "Activity time (HH:MM)" },
        "location": { "type": "string", "description": "Activity location" },
        "status": { "type": "string", "enum": ["pending", "completed"], "description": "Activity state" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "tripId", "name", "date", "time", "location", "status"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile metadata",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Owner user ID" },
        "name": { "type": "string", "description": "Display name" },
        "email": { "type": "string", "description": "User email address" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "email"]
    }
  },
  "firestore": {
    "trips/{tripId}": {
      "schema": "Trip",
      "description": "Collection of trips"
    },
    "activities/{activityId}": {
      "schema": "Activity",
      "description": "Collection of daily activities"
    },
    "profiles/{userId}": {
      "schema": "UserProfile",
      "description": "Collection of user profiles"
    }
  }
}
